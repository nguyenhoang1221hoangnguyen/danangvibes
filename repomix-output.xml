# Rotate logs older than 7 days
find $LOG_DIR -name "*.log" -mtime +7 -exec gzip {} \;
find $LOG_DIR -name "*.log.gz" -mtime +30 -delete

# Rotate current logs if > 100MB
for log in $LOG_DIR/*.log; do
